{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ethiopicreader.local/content/schema/v1/source-document.schema.json",
  "title": "Ethiopic Reader Source Document v1",
  "oneOf": [
    { "$ref": "#/$defs/structuredDocument" },
    { "$ref": "#/$defs/seasonalDocument" }
  ],
  "$defs": {
    "localizedText": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "gez": { "type": "string", "minLength": 1 },
        "am": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "gez-Latn": { "type": "string", "minLength": 1 }
      }
    },
    "sourceMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "saint": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
          "type": {
              "enum": ["manual", "pdf", "csv", "imported"]
            },
            "ref": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "dayOfWeek": {
      "enum": [
        "sunday",
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday"
      ]
    },
    "liturgicalSeason": {
      "enum": [
        "ordinary",
        "advent",
        "christmas",
        "lent",
        "easter",
        "pentecost"
      ]
    },
    "readingSlot": {
      "enum": ["pauline", "catholic", "acts", "psalm", "gospel"]
    },
    "speakerRole": {
      "enum": [
        "priest",
        "deacon",
        "assistant-priest",
        "assistant-deacon",
        "assembly",
        "all"
      ]
    },
    "condition": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "daysOfWeek": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/dayOfWeek" }
        },
        "seasons": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/liturgicalSeason" }
        },
        "feastIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "dateRanges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start", "end"],
            "properties": {
              "start": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "end": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              }
            }
          }
        }
      }
    },
    "textNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "role", "content"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "text" },
        "role": { "enum": ["prayer", "response"] },
        "speaker": { "$ref": "#/$defs/speakerRole" },
        "content": { "$ref": "#/$defs/localizedText" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "headingNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "content"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "heading" },
        "content": { "$ref": "#/$defs/localizedText" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rubricNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "content"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "rubric" },
        "content": { "$ref": "#/$defs/localizedText" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "readingRefNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "slot", "labels"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "reading-ref" },
        "slot": { "$ref": "#/$defs/readingSlot" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "style": {
          "enum": ["heading", "rubric"]
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "readingBodyNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "slot"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "reading-body" },
        "slot": { "$ref": "#/$defs/readingSlot" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "includeNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "ref"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "include" },
        "ref": {
          "type": "string",
          "pattern": "^[a-z0-9._-]+(?:#[a-z0-9._-]+)?$"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "seasonalRefNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "slot"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": { "const": "seasonal-ref" },
        "slot": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "optional": { "type": "boolean" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceNode": {
      "oneOf": [
        { "$ref": "#/$defs/textNode" },
        { "$ref": "#/$defs/headingNode" },
        { "$ref": "#/$defs/rubricNode" },
        { "$ref": "#/$defs/readingRefNode" },
        { "$ref": "#/$defs/readingBodyNode" },
        { "$ref": "#/$defs/includeNode" },
        { "$ref": "#/$defs/seasonalRefNode" }
      ]
    },
    "sourceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "titles", "nodes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "titles": { "$ref": "#/$defs/localizedText" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceNode" }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "structuredDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "id", "slug", "titles", "sections"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": {
          "enum": ["service", "anaphora", "fragment"]
        },
        "id": {
          "type": "string",
          "pattern": "^(service|anaphora|fragment)\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "titles": { "$ref": "#/$defs/localizedText" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceSection" }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": { "$ref": "#/$defs/sourceMetadata" }
      }
    },
    "seasonalRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "when", "nodes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "when": { "$ref": "#/$defs/condition" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceNode" }
        }
      }
    },
    "seasonalSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rules"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "titles": { "$ref": "#/$defs/localizedText" },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/seasonalRule" }
        }
      }
    },
    "seasonalDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "id", "slug", "titles", "slots"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "seasonal" },
        "id": {
          "type": "string",
          "pattern": "^seasonal\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "titles": { "$ref": "#/$defs/localizedText" },
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/seasonalSlot" }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": { "$ref": "#/$defs/sourceMetadata" }
      }
    }
  }
}
